NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

SLACK_FINANCE_WEBHOOK_URL=
SLACK_OPERATIONS_WEBHOOK_URL=

# Stigmergic coordination (zero-token inter-agent coordination via the StigmergyBoard).
# Off by default; set to 1 to derive Harmony conflicts from the board instead of the
# LLM-chat path. NEXT_PUBLIC_ variant is read by the client Harmony view; the bare
# variant is read by server-side coordination helpers.
NEXT_PUBLIC_STIGMERGY_COORDINATION=
STIGMERGY_COORDINATION=
